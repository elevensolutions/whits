{
	"compileOnSave": false,
	"compilerOptions": {
		"target": "ESNext",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"types": ["node"],
		"strictFunctionTypes": false,
		"useDefineForClassFields": false,
		"removeComments": false,
		"declaration": true,
		"sourceMap": true,
		"rootDir": "src",
		"outDir": "dist",
	},
	"include": [
		"src/**/*"
	]
}
